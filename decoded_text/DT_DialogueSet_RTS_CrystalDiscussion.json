      "DialogueText_10_10D44AC44144EC85326507BD9E2D1C2A": "NSLOCTEXT(\"\", \"8C42A6F94E5346ECDA700D80791F2792\", \"\\'Element A\\'. I have never, ever heard of it. Not at all. Holes right through the sieve.\")",
