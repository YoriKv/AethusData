    "NewRow_22": {
      "AchievementToTrigger_68_835137E74BC539A386BD80A4F1EDBF47": "",
      "CraftingRecipeToUnlock_63_1CD092944B18B837191688A9601C331F": "None",
      "CreditsToAdd_40_3D0A1C8B4368F62361047CB4BF00306B": "0",
      "DialogueAudio_4_E29DE7BE4E6FC9305309A0BB1B5AF65D": "/Script/Engine.SoundWave'/Game/StrikeTheEarth/Audio/Dialogue/Roland/Pass5Nov25/SecondBatch/DT_DialogueSet_RTS_CrystalDiscussion__Line4-001.DT_DialogueSet_RTS_CrystalDiscussion__Line4-001'",
      "DialogueText_10_10D44AC44144EC85326507BD9E2D1C2A": "NSLOCTEXT(\"\", \"435D67694AE719555A9483BA442DA517\", \"I find that hard to believe... Disturbingly, the anti-grav properties we\\'ve observed lead me to believe that this \\'Element A\\' is also the key to ARC\\'s anti-gravity technology.\")",
      "InfoportionRequirements_28_361F4D6B476653206A17849EBE1F42F3": "()",
