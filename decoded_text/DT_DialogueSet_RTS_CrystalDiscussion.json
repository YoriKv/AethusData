      "DialogueText_10_10D44AC44144EC85326507BD9E2D1C2A": "NSLOCTEXT(\"\", \"797ED8B342B6A760A68D6D81A4EA33BA\", \"Yeah, and what that resistance guy was talking about, right? The \\'non-standard\\' element? Stanley, do you know anything about it?\")",
