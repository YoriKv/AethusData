      "DialogueText_10_10D44AC44144EC85326507BD9E2D1C2A": "NSLOCTEXT(\"\", \"5C8A0CDA4FBA3B1985A0A09650B9634F\", \"Agreed. Let\\'s hope those laser drills are strong enough to crack that crystal.\")",
