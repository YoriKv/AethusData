      "CreditsToAdd_40_3D0A1C8B4368F62361047CB4BF00306B": "0",
      "DialogueAudio_4_E29DE7BE4E6FC9305309A0BB1B5AF65D": "/Script/Engine.SoundWave'/Game/StrikeTheEarth/Audio/Dialogue/Maeve/Nov25/DT_DialogueSet_RTS_CrystalDiscussion_line_4.DT_DialogueSet_RTS_CrystalDiscussion_line_4'",
      "DialogueText_10_10D44AC44144EC85326507BD9E2D1C2A": "NSLOCTEXT(\"\", \"03FDB637478762125E8C859288FE9C66\", \"Hm, true... They would have anti-grav tech too, if they had. No wonder they didn\\'t crack it though, if it does stuff like that to you when you go near it...\")",
