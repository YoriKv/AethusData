      "DialogueAudio_4_E29DE7BE4E6FC9305309A0BB1B5AF65D": "/Script/Engine.SoundWave'/Game/StrikeTheEarth/Audio/Dialogue/Maeve/Nov25/DT_DialogueSet_RTS_CrystalDiscussion_line_3.DT_DialogueSet_RTS_CrystalDiscussion_line_3'",
      "DialogueText_10_10D44AC44144EC85326507BD9E2D1C2A": "NSLOCTEXT(\"\", \"CF38EDA74AD24856B8E1548A6C73978A\", \"Oh my god... You must be right. It explains everything - why the Virtus facilities are down there, why Trudy is so obsessed with knowing what we\\'re finding...\")",
      "InfoportionRequirements_28_361F4D6B476653206A17849EBE1F42F3": "()",
