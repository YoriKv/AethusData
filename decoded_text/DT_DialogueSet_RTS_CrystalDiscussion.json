    "NewRow_24": {
      "AchievementToTrigger_68_835137E74BC539A386BD80A4F1EDBF47": "",
      "CraftingRecipeToUnlock_63_1CD092944B18B837191688A9601C331F": "None",
      "CreditsToAdd_40_3D0A1C8B4368F62361047CB4BF00306B": "0",
      "DialogueAudio_4_E29DE7BE4E6FC9305309A0BB1B5AF65D": "/Script/Engine.SoundWave'/Game/StrikeTheEarth/Audio/Dialogue/Roland/Pass5Nov25/SecondBatch/DT_DialogueSet_RTS_CrystalDiscussion__Line6-003.DT_DialogueSet_RTS_CrystalDiscussion__Line6-003'",
      "DialogueText_10_10D44AC44144EC85326507BD9E2D1C2A": "NSLOCTEXT(\"\", \"2C558DC748498246848F9CBD6504284C\", \"I agree. But I don\\'t think Virtus cracked it. The secret to the tech, that is. They found the element, but everything we\\'ve seen suggests they didn\\'t know how to use it properly.\")",
