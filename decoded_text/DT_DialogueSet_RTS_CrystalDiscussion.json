      "DialogueText_10_10D44AC44144EC85326507BD9E2D1C2A": "NSLOCTEXT(\"\", \"60F165A0461B20969134FEB08D61BD09\", \"We have to get past that crystal. Resistance or no resistance, this could be a huge breakthrough if we could get it out there!\")",
      "InfoportionRequirements_28_361F4D6B476653206A17849EBE1F42F3": "()",
