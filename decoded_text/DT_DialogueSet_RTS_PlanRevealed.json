      "DialogueText_10_10D44AC44144EC85326507BD9E2D1C2A": "NSLOCTEXT(\"\", \"1CEC285742C5038C3429DBB7F40DA236\", \"Exactly. High-yield, ultra-targeted, dropped from orbit. All the electronics at the site wiped out. All the way to the deepest part of their claim.\")",
