      "DialogueText_10_10D44AC44144EC85326507BD9E2D1C2A": "NSLOCTEXT(\"\", \"0F02BA8841273B614911BB9C97328496\", \"Sparkly, indeed... It\\'s a good plan. Almost as good as one of mine! I\\'m proud of you - let\\'s do it.\")",
