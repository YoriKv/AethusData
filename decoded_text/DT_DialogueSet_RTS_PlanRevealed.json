      "DialogueText_10_10D44AC44144EC85326507BD9E2D1C2A": "NSLOCTEXT(\"\", \"2B4E04054B6C3708549470AB0B39CB3A\", \"I\\'ve got a plan. Just like we did with the climber lockdown, we get into Omega with an EMP.\")",
      "InfoportionRequirements_28_361F4D6B476653206A17849EBE1F42F3": "()",
      "InfoportionsToSet_19_F3CEC1734ED5DFFD1E1C3087F2E00348": "((\"IP_Dialogue_RTS_PlanRevealed_Complete\", True))",
