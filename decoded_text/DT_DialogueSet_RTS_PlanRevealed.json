      "DialogueText_10_10D44AC44144EC85326507BD9E2D1C2A": "NSLOCTEXT(\"\", \"03D467E045558F353794C98B84F6ACF8\", \"We just need to get Trudy to trigger the Kuiper Protocol on us, and I am sure it\\'ll open up Omega.\")",
