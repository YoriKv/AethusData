      "CreditsToAdd_40_3D0A1C8B4368F62361047CB4BF00306B": "0",
      "DialogueAudio_4_E29DE7BE4E6FC9305309A0BB1B5AF65D": "/Script/Engine.SoundWave'/Game/StrikeTheEarth/Audio/Dialogue/Roland/Pass5Nov25/SecondBatch/DT_DialogueSet_RTS_PlanRevealed_Line14-001.DT_DialogueSet_RTS_PlanRevealed_Line14-001'",
      "DialogueText_10_10D44AC44144EC85326507BD9E2D1C2A": "NSLOCTEXT(\"\", \"BBC04B9048427EF40CCCFBA525180258\", \"It\\'ll also shut down the Outpost, Maeve... How do we use the antenna to broadcast whatever we find, if it\\'s been fried?\")",
      "InfoportionRequirements_28_361F4D6B476653206A17849EBE1F42F3": "()",
      "InfoportionsToSet_19_F3CEC1734ED5DFFD1E1C3087F2E00348": "()",
