      "DialogueText_10_10D44AC44144EC85326507BD9E2D1C2A": "NSLOCTEXT(\"\", \"F58B71384986F99250ED41A86E0C062F\", \"I think he\\'s saying it\\'s shielded from electromagnetic interference, Maeve. There\\'s no way we could build an EMP charge large enough to overcome hardened shielding...\")",
