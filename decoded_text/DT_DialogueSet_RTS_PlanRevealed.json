    "NewRow_16": {
      "AchievementToTrigger_68_835137E74BC539A386BD80A4F1EDBF47": "",
      "CraftingRecipeToUnlock_63_1CD092944B18B837191688A9601C331F": "RemoteRestartChip",
      "CreditsToAdd_40_3D0A1C8B4368F62361047CB4BF00306B": "0",
      "DialogueAudio_4_E29DE7BE4E6FC9305309A0BB1B5AF65D": "/Script/Engine.SoundWave'/Game/StrikeTheEarth/Audio/Dialogue/Maeve/Nov25/Revisions/DT_DialogueSet_RTS_PlanRevealed_line_7.DT_DialogueSet_RTS_PlanRevealed_line_7'",
      "DialogueText_10_10D44AC44144EC85326507BD9E2D1C2A": "NSLOCTEXT(\"\", \"A87E606B4C818D614C0C959ACD9E80D3\", \"We\\'ll create a remote-restart chip, put it into the antenna and trigger a shutdown before the EMP hits. Then, we\\'ll start it up again afterwards when we need to broadcast.\")",
