      "DialogueText_10_10D44AC44144EC85326507BD9E2D1C2A": "NSLOCTEXT(\"\", \"791B400E471649ACC566C68C33CE33E8\", \"Leonard, I wouldn\\'t work for you if Virtus was the last megacorp in the galaxy. I\\'m an ARC girl through-and-through.\")",
      "InfoportionRequirements_28_361F4D6B476653206A17849EBE1F42F3": "()",
      "InfoportionsToSet_19_F3CEC1734ED5DFFD1E1C3087F2E00348": "()",
