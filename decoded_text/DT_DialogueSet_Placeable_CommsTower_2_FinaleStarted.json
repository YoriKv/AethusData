      "DialogueText_10_10D44AC44144EC85326507BD9E2D1C2A": "NSLOCTEXT(\"\", \"97C44CBD43E6E7EA38331EA00CC155C5\", \"Oh shut up, Maeve. Wah wah wah, \\\"everyone is so mean!\\\". Do you ever stop complaining? You had a chance to make something here, and let me tell you, that\\'s finished.\")",
      "InfoportionRequirements_28_361F4D6B476653206A17849EBE1F42F3": "()",
