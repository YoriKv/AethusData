    "NewRow_17": {
      "AchievementToTrigger_68_835137E74BC539A386BD80A4F1EDBF47": "",
      "CraftingRecipeToUnlock_63_1CD092944B18B837191688A9601C331F": "None",
      "CreditsToAdd_40_3D0A1C8B4368F62361047CB4BF00306B": "0",
      "DialogueAudio_4_E29DE7BE4E6FC9305309A0BB1B5AF65D": "/Script/Engine.SoundWave'/Game/StrikeTheEarth/Audio/Dialogue/Trudy/Nov25/DT_DialogueSet_FinaleStarted_14b.DT_DialogueSet_FinaleStarted_14b'",
      "DialogueText_10_10D44AC44144EC85326507BD9E2D1C2A": "NSLOCTEXT(\"\", \"07EDB5D44ECDA227A370BABC1533142D\", \"Wait, I know that voice, even with the silly filter... Leonard. Ugh, Maeve, you could have at least picked a classier megacorp to betray us to. Even the Yakatani Group would have been less... pedestrian.\")",
      "InfoportionRequirements_28_361F4D6B476653206A17849EBE1F42F3": "()",
