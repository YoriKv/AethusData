      "TutorialToPush_14_2E68018D412A7410516B3CB4952C46FB": "NewEnumerator5"
    },
    "NewRow_21": {
      "AchievementToTrigger_68_835137E74BC539A386BD80A4F1EDBF47": "",
      "CraftingRecipeToUnlock_63_1CD092944B18B837191688A9601C331F": "None",
      "CreditsToAdd_40_3D0A1C8B4368F62361047CB4BF00306B": "0",
      "DialogueAudio_4_E29DE7BE4E6FC9305309A0BB1B5AF65D": "/Script/Engine.SoundWave'/Game/StrikeTheEarth/Audio/Dialogue/Maeve/Nov25/DT_DialogueSet_FinaleStarted_line_2.DT_DialogueSet_FinaleStarted_line_2'",
      "DialogueText_10_10D44AC44144EC85326507BD9E2D1C2A": "NSLOCTEXT(\"\", \"D8542EE243278E8FA7802B9965029A97\", \"Hey, hang on, I\\'m not betraying anyone! I\\'m just done being used by both of you!\")",
      "InfoportionRequirements_28_361F4D6B476653206A17849EBE1F42F3": "()",
      "InfoportionsToSet_19_F3CEC1734ED5DFFD1E1C3087F2E00348": "()",
