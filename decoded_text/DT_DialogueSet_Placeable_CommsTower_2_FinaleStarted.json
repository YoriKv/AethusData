    "NewRow_18": {
      "AchievementToTrigger_68_835137E74BC539A386BD80A4F1EDBF47": "",
      "CraftingRecipeToUnlock_63_1CD092944B18B837191688A9601C331F": "None",
      "CreditsToAdd_40_3D0A1C8B4368F62361047CB4BF00306B": "0",
      "DialogueAudio_4_E29DE7BE4E6FC9305309A0BB1B5AF65D": "/Script/Engine.SoundWave'/Game/StrikeTheEarth/Audio/Dialogue/Resistance/November25/Batch_2/output_23_.output_23_'",
      "DialogueText_10_10D44AC44144EC85326507BD9E2D1C2A": "NSLOCTEXT(\"\", \"EBAB3E0D4C19D4A90DCAE9A64675EE50\", \"Ah. Guilty as charged. I did worry you might have pieced things together after we didn\\'t hear from you for a good while... Proven right again, it seems.\")",
      "InfoportionRequirements_28_361F4D6B476653206A17849EBE1F42F3": "()",
