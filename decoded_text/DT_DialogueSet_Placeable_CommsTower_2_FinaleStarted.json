      "DialogueText_10_10D44AC44144EC85326507BD9E2D1C2A": "NSLOCTEXT(\"\", \"19BB025A40106C2144D8E89F3EAE9403\", \"Maeve, you can\\'t call us on this band, it isn\\'t secure!\")",
