      "DialogueText_10_10D44AC44144EC85326507BD9E2D1C2A": "NSLOCTEXT(\"\", \"1094EF7947F825438517D6B4675A7544\", \"I know what it\\'s like to not know who you are, or what your purpose is. We can\\'t decide for you, but I know doing it alone doesn\\'t work.\")",
