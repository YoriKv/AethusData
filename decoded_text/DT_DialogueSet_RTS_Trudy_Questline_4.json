      "DialogueText_10_10D44AC44144EC85326507BD9E2D1C2A": "NSLOCTEXT(\"\", \"EA4FE2B44C35F0F7FD77749A72E6FB12\", \"So, let\\'s hold our noses and get those microcircuits, eh? I\\'ll send over some credits when you\\'re done. Toodles!\")",
