      "DialogueText_10_10D44AC44144EC85326507BD9E2D1C2A": "NSLOCTEXT(\"\", \"BBA6E51F4BF2C411D52FAEBC4E5AF147\", \"Find the Tether Bridge, and take the gondola across to the mine. You\\'ll know it when you see it. Be careful, both of you.\")",
