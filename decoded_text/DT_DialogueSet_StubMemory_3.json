    "NewRow_2": {
      "AchievementToTrigger_68_835137E74BC539A386BD80A4F1EDBF47": "",
      "CraftingRecipeToUnlock_63_1CD092944B18B837191688A9601C331F": "None",
      "CreditsToAdd_40_3D0A1C8B4368F62361047CB4BF00306B": "0",
      "DialogueAudio_4_E29DE7BE4E6FC9305309A0BB1B5AF65D": "/Script/Engine.SoundWave'/Game/StrikeTheEarth/Audio/Dialogue/Grandad/Nov25/DT_DialogueSet_StubMemory_3_2_Take_3.DT_DialogueSet_StubMemory_3_2_Take_3'",
      "DialogueText_10_10D44AC44144EC85326507BD9E2D1C2A": "NSLOCTEXT(\"\", \"9E1F34AE4C264DA1901F219BA8848C31\", \"As you may have guessed, I need you to find a place called Kryptos. That facility is... not like the others. There was light in what we did in some of those places... There was no light at all in Kryptos.\")",
      "InfoportionRequirements_28_361F4D6B476653206A17849EBE1F42F3": "()",
      "InfoportionsToSet_19_F3CEC1734ED5DFFD1E1C3087F2E00348": "()",
