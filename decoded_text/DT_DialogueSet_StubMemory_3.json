      "DialogueText_10_10D44AC44144EC85326507BD9E2D1C2A": "NSLOCTEXT(\"\", \"D7D93A224111DBACF0FF9993717BE9FA\", \"I must warn you to be careful, going forward. I cannot bear the thought of anything happening to either of you.\")",
