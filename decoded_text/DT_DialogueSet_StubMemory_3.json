      "DialogueText_10_10D44AC44144EC85326507BD9E2D1C2A": "NSLOCTEXT(\"\", \"034B50414D33ACB2664660B467A74767\", \"I\\'ve babbled enough, I\\'m sorry. It just... almost feels like I can see you there, listening... *sighs* \")",
