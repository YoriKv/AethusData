    "NewRow_5": {
      "AchievementToTrigger_68_835137E74BC539A386BD80A4F1EDBF47": "",
      "CraftingRecipeToUnlock_63_1CD092944B18B837191688A9601C331F": "None",
      "CreditsToAdd_40_3D0A1C8B4368F62361047CB4BF00306B": "0",
      "DialogueAudio_4_E29DE7BE4E6FC9305309A0BB1B5AF65D": "/Script/Engine.SoundWave'/Game/StrikeTheEarth/Audio/Dialogue/Grandad/Nov25/DT_DialogueSet_StubMemory_3_6_Take_1.DT_DialogueSet_StubMemory_3_6_Take_1'",
      "DialogueText_10_10D44AC44144EC85326507BD9E2D1C2A": "NSLOCTEXT(\"\", \"BB2EE67340A0FE2753371981455BAF4E\", \"Roland, you will know what to do once you gain access to Sigma. Show Maeve how to get there, and go together. I wish I did not have to send you there... but it\\'s the only way.\")",
      "InfoportionRequirements_28_361F4D6B476653206A17849EBE1F42F3": "()",
