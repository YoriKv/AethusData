      "DialogueAudio_4_E29DE7BE4E6FC9305309A0BB1B5AF65D": "/Script/Engine.SoundWave'/Game/StrikeTheEarth/Audio/Dialogue/Grandad/Nov25/DT_DialogueSet_StubMemory_3_7_Take_1.DT_DialogueSet_StubMemory_3_7_Take_1'",
      "DialogueText_10_10D44AC44144EC85326507BD9E2D1C2A": "NSLOCTEXT(\"\", \"F4B64F8F4D5B4D3DFC8373B73A7B0EE6\", \"The riches in Seam X-5, where you found my keycard, will enable you to buy any supplies you might need. Take care - ARC are jealous protectors of anything of value within this poor, drained planet.\")",
      "InfoportionRequirements_28_361F4D6B476653206A17849EBE1F42F3": "()",
