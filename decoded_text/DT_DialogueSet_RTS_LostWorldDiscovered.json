      "DialogueText_10_10D44AC44144EC85326507BD9E2D1C2A": "NSLOCTEXT(\"\", \"5F45150B468BBDF80D6A7FB65C76FE2A\", \"Well, maybe those fairytales will prove true and we\\'ll find the treasure. Maybe that\\'s why he sent you here.\")",
