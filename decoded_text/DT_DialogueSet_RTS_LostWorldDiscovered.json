      "DialogueText_10_10D44AC44144EC85326507BD9E2D1C2A": "NSLOCTEXT(\"\", \"C2EC14954F73564FD6F34181345A1762\", \"Grandad used to read me fairytales... Y\\'know, elves in magical forests full of treasure, that sort of stuff... It was like stepping into one of those stories. Ah, Roland, I miss him.\")",
