      "DialogueText_10_10D44AC44144EC85326507BD9E2D1C2A": "NSLOCTEXT(\"\", \"0C11D98040C61F1A3D34F99A3B541D68\", \"Don\\'t you want to make life better for everyone living under ARC\\'s yoke?\")",
      "InfoportionRequirements_28_361F4D6B476653206A17849EBE1F42F3": "()",
      "InfoportionsToSet_19_F3CEC1734ED5DFFD1E1C3087F2E00348": "()",
      "JournalEntryToAdd_43_36DF753B4BE2FE20540716B6BCF44533": "None",
