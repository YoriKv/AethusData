      "DialogueText_10_10D44AC44144EC85326507BD9E2D1C2A": "NSLOCTEXT(\"\", \"9824764147906E204B1872A97374156A\", \"Simple, we\\'ll pay you for whatever data you find. We can provide decoder software that will analyse the complexity of the data you find - more complex data is worth more.\")",
      "InfoportionRequirements_28_361F4D6B476653206A17849EBE1F42F3": "()",
      "InfoportionsToSet_19_F3CEC1734ED5DFFD1E1C3087F2E00348": "()",
