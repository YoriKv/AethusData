      "DialogueText_10_10D44AC44144EC85326507BD9E2D1C2A": "NSLOCTEXT(\"\", \"7AA73C024C06C1D2066AFDB54DDAB05D\", \"Like I said, I know. But I finally have a chance to make something for myself here. I can\\'t risk it for vague dreams of revolution.\")",
      "InfoportionRequirements_28_361F4D6B476653206A17849EBE1F42F3": "()",
      "InfoportionsToSet_19_F3CEC1734ED5DFFD1E1C3087F2E00348": "()",
