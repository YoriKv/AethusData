      "DialogueText_10_10D44AC44144EC85326507BD9E2D1C2A": "NSLOCTEXT(\"\", \"7DF41BE14CE68BDA6BE968A32D60F03C\", \"Tech that Chapman was working on - utility-scale teleportation. Small enough to send someone to a paired location, perhaps with a charming sidekick, yet keep its power signature undetectable.\")",
