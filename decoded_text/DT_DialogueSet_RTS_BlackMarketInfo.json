      "DialogueText_10_10D44AC44144EC85326507BD9E2D1C2A": "NSLOCTEXT(\"\", \"5E8028BB48BFF8184C867995892AC76A\", \"We\\'ll get to that. Before we take the next step though, we need to confirm there is actually data down there.\")",
      "InfoportionRequirements_28_361F4D6B476653206A17849EBE1F42F3": "()",
