      "DialogueText_10_10D44AC44144EC85326507BD9E2D1C2A": "NSLOCTEXT(\"\", \"7E8D356D44AD98A4FEB36D995B6889A2\", \"Cutting right to the chase, I like it. We\\'re what you might call a... resistance. Against ARC.\")",
