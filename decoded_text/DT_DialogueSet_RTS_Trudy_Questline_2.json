      "DialogueText_10_10D44AC44144EC85326507BD9E2D1C2A": "NSLOCTEXT(\"\", \"135D63DC45D8BDBA4AED3BA125BBBA55\", \"He needs their eggs! For his menagerie, obviously. Not to eat. That would be weird!\")",
