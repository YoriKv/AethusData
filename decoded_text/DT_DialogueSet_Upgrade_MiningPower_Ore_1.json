      "DialogueText_10_10D44AC44144EC85326507BD9E2D1C2A": "NSLOCTEXT(\"\", \"19791F4448ACB35650DDF099EB1092E8\", \"Ok, it\\'s dark humour, but it\\'s been a hundred years. Are we not over it yet?\")",
