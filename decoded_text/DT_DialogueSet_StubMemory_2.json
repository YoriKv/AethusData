      "DialogueAudio_4_E29DE7BE4E6FC9305309A0BB1B5AF65D": "/Script/Engine.SoundWave'/Game/StrikeTheEarth/Audio/Dialogue/Grandad/Nov25/DT_DialogueSet_StubMemory_2_1_Take_1.DT_DialogueSet_StubMemory_2_1_Take_1'",
      "DialogueText_10_10D44AC44144EC85326507BD9E2D1C2A": "NSLOCTEXT(\"\", \"330BC43C4AA5E89DD7F092B0D24CA736\", \"Hello Maeve. And you too, Roland. I\\'m sure it\\'s a shock hearing my voice, especially down here. And I\\'m sure you have a lot of questions. \")",
