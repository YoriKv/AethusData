    "NewRow_6": {
      "AchievementToTrigger_68_835137E74BC539A386BD80A4F1EDBF47": "",
      "CraftingRecipeToUnlock_63_1CD092944B18B837191688A9601C331F": "None",
      "CreditsToAdd_40_3D0A1C8B4368F62361047CB4BF00306B": "0",
      "DialogueAudio_4_E29DE7BE4E6FC9305309A0BB1B5AF65D": "/Script/Engine.SoundWave'/Game/StrikeTheEarth/Audio/Dialogue/Grandad/Nov25/DT_DialogueSet_StubMemory_2_6_Take_3.DT_DialogueSet_StubMemory_2_6_Take_3'",
      "DialogueText_10_10D44AC44144EC85326507BD9E2D1C2A": "NSLOCTEXT(\"\", \"C7AB9217428A22BED5771583EBD44446\", \"This claim contains more than just valuable rocks. It contains hubris. Deceit. Misdirected genius. And greed. It contains secrets, whose fate you\\'ll have to decide. God knows we proved manifestly inadequate to that task.\")",
      "InfoportionRequirements_28_361F4D6B476653206A17849EBE1F42F3": "()",
      "InfoportionsToSet_19_F3CEC1734ED5DFFD1E1C3087F2E00348": "()",
