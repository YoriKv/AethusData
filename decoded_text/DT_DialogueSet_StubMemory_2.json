    "NewRow_4": {
      "AchievementToTrigger_68_835137E74BC539A386BD80A4F1EDBF47": "",
      "CraftingRecipeToUnlock_63_1CD092944B18B837191688A9601C331F": "None",
      "CreditsToAdd_40_3D0A1C8B4368F62361047CB4BF00306B": "0",
      "DialogueAudio_4_E29DE7BE4E6FC9305309A0BB1B5AF65D": "/Script/Engine.SoundWave'/Game/StrikeTheEarth/Audio/Dialogue/Grandad/Nov25/DT_DialogueSet_StubMemory_2_4_Take_2.DT_DialogueSet_StubMemory_2_4_Take_2'",
      "DialogueText_10_10D44AC44144EC85326507BD9E2D1C2A": "NSLOCTEXT(\"\", \"1E282D6D442C9622300DABBDB317D1FC\", \"I apologise for abusing the trust you placed in me to conduct your maintenance, Roland. But there is so much I could not make myself tell you both, even though I should have. \")",
      "InfoportionRequirements_28_361F4D6B476653206A17849EBE1F42F3": "()",
      "InfoportionsToSet_19_F3CEC1734ED5DFFD1E1C3087F2E00348": "()",
