      "DialogueAudio_4_E29DE7BE4E6FC9305309A0BB1B5AF65D": "/Script/Engine.SoundWave'/Game/StrikeTheEarth/Audio/Dialogue/Grandad/Nov25/DT_DialogueSet_StubMemory_2_9_Take_3.DT_DialogueSet_StubMemory_2_9_Take_3'",
      "DialogueText_10_10D44AC44144EC85326507BD9E2D1C2A": "NSLOCTEXT(\"\", \"0AC040094FC224C68DB7C8A762DD8180\", \"Know that you are both more important to me than I could ever say. I love you.\")",
      "InfoportionRequirements_28_361F4D6B476653206A17849EBE1F42F3": "()",
