      "DialogueText_10_10D44AC44144EC85326507BD9E2D1C2A": "NSLOCTEXT(\"\", \"23AD8F4C423D1EEC66D43D9BCE85A406\", \"I\\'ll answer some. And ask you to trust me that answers for others will come in time.\")",
