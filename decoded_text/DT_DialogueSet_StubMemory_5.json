      "DialogueText_10_10D44AC44144EC85326507BD9E2D1C2A": "NSLOCTEXT(\"\", \"D62A4DA34F0105F91ACF65B97002147B\", \"In the end, our choices are the only thing we can truly control. I did not realise that until it was too late.\")",
