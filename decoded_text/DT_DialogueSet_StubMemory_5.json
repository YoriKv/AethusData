      "DialogueText_10_10D44AC44144EC85326507BD9E2D1C2A": "NSLOCTEXT(\"\", \"5DDF03F24F1F534762115AA12E3C81BB\", \"I am sorry I was not brave enough to do this in person. So sorry...\")",
