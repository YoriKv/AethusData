      "DialogueText_10_10D44AC44144EC85326507BD9E2D1C2A": "NSLOCTEXT(\"\", \"18BD3782437091CBF715A4BCDD66FFBF\", \"Great huh! Well, we are certainly looking forward to receiving your first shipment - we\\'ll purchase almost anything you have to offer! You won\\'t get a better price elsewhere, that\\'s the ARC promise. Speak soon, Maeve!\")",
