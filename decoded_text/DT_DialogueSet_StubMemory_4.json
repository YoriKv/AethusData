      "TutorialIDToPush_49_090D89AD47BDBE905171749E514A8665": "None",
      "TutorialToPush_14_2E68018D412A7410516B3CB4952C46FB": "NewEnumerator5"
    },
    "NewRow_8": {
      "AchievementToTrigger_68_835137E74BC539A386BD80A4F1EDBF47": "",
      "CraftingRecipeToUnlock_63_1CD092944B18B837191688A9601C331F": "None",
      "CreditsToAdd_40_3D0A1C8B4368F62361047CB4BF00306B": "0",
      "DialogueAudio_4_E29DE7BE4E6FC9305309A0BB1B5AF65D": "/Script/Engine.SoundWave'/Game/StrikeTheEarth/Audio/Dialogue/Grandad/Nov25/DT_DialogueSet_StubMemory_4_11_Take_1.DT_DialogueSet_StubMemory_4_11_Take_1'",
      "DialogueText_10_10D44AC44144EC85326507BD9E2D1C2A": "NSLOCTEXT(\"\", \"3C8946A44B24DAF4897AAA8B80C22F42\", \"As far as anyone knows, Aetherium is only formed deep within the crust of this one world. Unique in the galaxy, perhaps.\")",
      "InfoportionRequirements_28_361F4D6B476653206A17849EBE1F42F3": "()",
      "InfoportionsToSet_19_F3CEC1734ED5DFFD1E1C3087F2E00348": "()",
