      "DialogueText_10_10D44AC44144EC85326507BD9E2D1C2A": "NSLOCTEXT(\"\", \"475894454428BA486696B1BB422708D8\", \"ARC discovered, studied and mastered Aetherium, creating the anti-gravity technology that today provides them commercial dominance across human space.\")",
      "InfoportionRequirements_28_361F4D6B476653206A17849EBE1F42F3": "()",
