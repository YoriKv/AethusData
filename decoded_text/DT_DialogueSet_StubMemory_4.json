      "CreditsToAdd_40_3D0A1C8B4368F62361047CB4BF00306B": "0",
      "DialogueAudio_4_E29DE7BE4E6FC9305309A0BB1B5AF65D": "/Script/Engine.SoundWave'/Game/StrikeTheEarth/Audio/Dialogue/Grandad/Nov25/DT_DialogueSet_StubMemory_4_8_Take_1.DT_DialogueSet_StubMemory_4_8_Take_1'",
      "DialogueText_10_10D44AC44144EC85326507BD9E2D1C2A": "NSLOCTEXT(\"\", \"53C82AD240ED1066AD9A7F9FCDA64AA6\", \"If you want more answers, find the Omega facility - the centre of all the corruption in this place, where every record of every dark experiment still resides, just waiting to be exposed to the light.\")",
      "InfoportionRequirements_28_361F4D6B476653206A17849EBE1F42F3": "()",
