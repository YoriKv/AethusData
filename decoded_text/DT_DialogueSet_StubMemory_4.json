      "DialogueText_10_10D44AC44144EC85326507BD9E2D1C2A": "NSLOCTEXT(\"\", \"64872FA944CDD63F2932B8A421D3DFAC\", \"As you know now, we did eventually discover the key - true human consciousness, blended with machine technology.\")",
