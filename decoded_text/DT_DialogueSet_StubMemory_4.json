      "DialogueText_10_10D44AC44144EC85326507BD9E2D1C2A": "NSLOCTEXT(\"\", \"797FBE4B4D4CD91EBB203485CD1C3860\", \"Over time, we discovered Aetherium and its properties, but couldn\\'t crack the final step - safely extracting it in large enough quantities for any useful purpose.\")",
