      "DialogueAudio_4_E29DE7BE4E6FC9305309A0BB1B5AF65D": "/Script/Engine.SoundWave'/Game/StrikeTheEarth/Audio/Dialogue/Grandad/Nov25/DT_DialogueSet_StubMemory_4_3_Take_1.DT_DialogueSet_StubMemory_4_3_Take_1'",
      "DialogueText_10_10D44AC44144EC85326507BD9E2D1C2A": "NSLOCTEXT(\"\", \"26C708664DBE3CA7756AF19AA834EF58\", \"Our expedition was sent by Virtus Ltd to uncover the secret to that tech, and recover it for their use. Without it, ARC would always remain the most powerful of all the corporations.\")",
