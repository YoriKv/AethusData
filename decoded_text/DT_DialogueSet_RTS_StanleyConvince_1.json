      "DialogueText_10_10D44AC44144EC85326507BD9E2D1C2A": "NSLOCTEXT(\"\", \"BA1871A0446F91579C30B28BD4922139\", \"He was... distant. He used to work in some big research lab. Until he left. Or was fired. He would never talk about what he did, just how important it was. \")",
