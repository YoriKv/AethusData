      "TutorialText_11_F5F98E9C47DA80DC659CA9985D7C6A24": "NSLOCTEXT(\"\", \"1C80D1B24EE7FFAACB427DB766340F26\", \"You can open and view your <Important>Inventory</> and its contents with <Cyan>(TAB)</>.\\r\\n\\r\\nWalking over loose items in the world will add them to your <Important>Inventory</>.\\r\\n\\r\\nThese items can also be pulled towards you when in range by hovering them and using <img id=\\\"LMB\\\"/> <Cyan>(LMB)</>.\\r\\n\\r\\n<Important>Hovering</> an item in your <Important>Inventory</> will show more information about it\\r\\n<Important>Consume</> items in your <Important>Inventory</> with  <img id=\\\"MMB\\\"/> <Cyan>(MMB)</>.\\r\\n\\r\\n\\r\\n<Important>Consume</> the Cactus Fruit with <img id=\\\"MMB\\\"/> <Cyan>(MMB)</>. to improve Maeve\\'s <Important>Vitality</>.\")",
