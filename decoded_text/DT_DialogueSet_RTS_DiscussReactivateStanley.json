      "DialogueText_10_10D44AC44144EC85326507BD9E2D1C2A": "NSLOCTEXT(\"\", \"ED1343E54EC77C96CAE38EBC94B92998\", \"Oh no, it\\'s fine - standard AI tech... Like flicking a light switch. He\\'ll be fine once we turn it back on. Probably won\\'t even realise it happened.\")",
